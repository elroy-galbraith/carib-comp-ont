# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Generated files — do not commit vault.ttl directly; regenerate from vault/*.md
# Pattern (no leading slash, contains slash) matches at the repo root AND under
# any projects/<name>/vault/ subfolder.
vault.ttl
**/vault.ttl

# Inbox PDFs — processing payloads; keep history clean
inbox/*.pdf

# Environment / secrets — never commit credentials
.env
*.env
secrets/
*.key
*.pem
*.p12
*.pfx

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Demo assets — track the folder, ignore the large binary files inside
demo_assets/*.pdf
demo_assets/*.PDF
demo_assets/*.mp4
demo_assets/*.mov

# Vault source PDFs — staged inside the vault so Obsidian can link to them
# at vault/sources/<doc>.pdf#page=N. Large; don't track in git.
vault/sources/*.pdf
vault/sources/*.PDF

# Held-out corpus — evaluation integrity; PDF must never be committed
held-out/

# Phase A regression-test scratch — captured pre/post baselines for diffing
baselines/
baselines_pre/
baselines_post/
