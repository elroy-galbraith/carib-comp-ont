@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tha:  <https://ontology.example.org/thematic/> .
@prefix thae: <https://ontology.example.org/thematic/entity/> .


thae:interview01_excerpt_t0830
    a tha:Excerpt ;
    rdfs:label "P01 on feeling excluded"@en ;
    skos:definition """It just feels like decisions about my information happen behind closed doors. Nobody sits me down to explain it."""@en ;
    dcterms:source "Interview 01 / 08:30" ;
    tha:codedAs thae:thematic_code_feeling_shut_out ;
    tha:supportsTheme thae:thematic_theme_loss_of_control ;
    tha:spokenBy "P01" .

thae:interview02_excerpt_t0212
    a tha:Excerpt ;
    rdfs:label "P02 on opaque institutions"@en ;
    skos:definition """The bank never says why they need any of it. They just hand you a form and tick a box."""@en ;
    dcterms:source "Interview 02 / 02:12" ;
    tha:codedAs thae:thematic_code_institutions_dont_explain ;
    tha:supportsTheme thae:thematic_theme_distrust_of_institutions ;
    tha:spokenBy "P02" .

thae:interview03_excerpt_t1422
    a tha:Excerpt ;
    rdfs:label "P03 on data transparency"@en ;
    skos:definition """I just felt completely shut out — like nobody was telling me what was actually going on with my data."""@en ;
    dcterms:source "Interview 03 / 14:22" ;
    tha:codedAs thae:thematic_code_lack_of_transparency ;
    tha:supportsTheme thae:thematic_theme_loss_of_control ;
    tha:spokenBy "P03" .

thae:interview03_excerpt_t1845
    a tha:Excerpt ;
    rdfs:label "P03 on institutional opacity"@en ;
    skos:definition """Even when I asked the hospital point-blank, they wouldn't say where my records were going."""@en ;
    dcterms:source "Interview 03 / 18:45" ;
    tha:codedAs thae:thematic_code_institutions_dont_explain ;
    tha:supportsTheme thae:thematic_theme_distrust_of_institutions ;
    tha:spokenBy "P03" .

thae:thematic_code_feeling_shut_out
    a tha:Code ;
    rdfs:label "Feeling shut out"@en ;
    skos:definition """Participant uses language of exclusion or being kept in the dark."""@en ;
    dcterms:source "code" .

thae:thematic_code_institutions_dont_explain
    a tha:Code ;
    rdfs:label "Institutions don't explain"@en ;
    skos:definition """Participant ascribes opacity to a specific institution (bank, hospital, government)."""@en ;
    dcterms:source "code" .

thae:thematic_code_lack_of_transparency
    a tha:Code ;
    rdfs:label "Lack of transparency"@en ;
    skos:definition """Participant explicitly states they were not told how their data is being used."""@en ;
    dcterms:source "code" .

thae:thematic_subtheme_lack_of_transparency
    a tha:Subtheme ;
    rdfs:label "Lack of Transparency"@en ;
    skos:definition """A sub-theme of Loss of Control — participants explicitly mention not being told how their data is used."""@en ;
    dcterms:source "synthesis" .

thae:thematic_theme_distrust_of_institutions
    a tha:Theme ;
    rdfs:label "Distrust of Institutions"@en ;
    skos:definition """A scepticism toward the institutions handling personal data, rooted in repeated unexplained encounters."""@en ;
    dcterms:source "synthesis" .

thae:thematic_theme_loss_of_control
    a tha:Theme ;
    rdfs:label "Loss of Control"@en ;
    skos:definition """A pervasive sense that participants have lost agency over how their personal data is collected and used."""@en ;
    dcterms:source "synthesis" ;
    tha:hasSubtheme thae:thematic_subtheme_lack_of_transparency .
